{
  "schemaVersion": 1,
  "id": "zenoptimize",
  "version": "${version}",
  "name": "ZenOptimize",
  "description": "Boost FPS and reduce lag spikes on Android launchers (Zalith, PojavLauncher, MojoLauncher). Sodium/Lithium/Iris compatible.",
  "authors": ["Zen"],
  "contact": {
    "sources": "https://github.com/dvaustria741-a11y/ZenOptimize"
  },
  "license": "MIT",
  "environment": "client",
  "entrypoints": {
    "client": ["com.zenoptimize.ZenOptimizeMod"]
  },
  "mixins": ["zenoptimize.mixins.json"],
  "depends": {
    "fabricloader": ">=0.19.3",
    "minecraft": "~1.21.11",
    "java": ">=21",
    "fabric-api": "*"
  },
  "suggests": {
    "sodium": "*",
    "lithium": "*",
    "iris": "*",
    "indium": "*"
  },
  "custom": {
    "modmenu:badges": ["library"],
    "modmenu:links": {
      "modmenu.discord": ""
    }
  }
}
